{
  "name": "invoice-manager",
  "version": "3.1.0",
  "description": "发票管家 — 多账号财务管理系统",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --output dist/发票管家.exe"
  },
  "pkg": {
    "assets": [
      "pages/**/*",
      "css/**/*",
      "js/**/*",
      "server/**/*",
      "db/schema.sql",
      "index.html",
      "login.html",
      "data.json",
      "config.example.json"
    ]
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0"
  }
}